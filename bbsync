#!/usr/bin/env bash
# bbsync — dump UX570 (or any Sony IC RECORDER) → host blackbox pipeline.
# Detects mounted recorder, prompts for tags, rsyncs to host:~/blackbox-incoming/.
#
# Usage:
#   bbsync                       Interactive: auto-detect mount, prompt for tags
#   bbsync --source PATH         Override source directory
#   bbsync --no-prompt           Skip tag prompt (no tags applied)
#   bbsync --dry-run             Show what would happen, don't transfer
#
# Configure: set BLACKBOX_HOST in your shell env (or ~/.ssh/config Host alias)
# to the SSH target running bounce_blackbox.sh. Default: "blackbox-host".

set -euo pipefail

HOST="${BLACKBOX_HOST:-blackbox-host}"
# Use relative path so rsync resolves to the remote user's $HOME automatically.
# (Literal "$HOME" in rsync destinations is NOT expanded server-side.)
HOST_INCOMING_REL="blackbox-incoming"

# Local staging dir. USB reads from IC recorders are unreliable on sustained
# transfers (device power-cycles or drops off the bus mid-rsync). Two-stage
# upload — recorder → local SSD → host — decouples the flaky USB read from
# the network transfer so a dropped USB connection doesn't kill a half-done
# upload. Partial files are retained across runs; rerun bbsync to resume.
STAGE_BASE="$HOME/.bbsync-stage"

# Sony UX570 stores REC-button files in REC_FILE/FOLDER01..05 (default REC button mode)
# and Scene/preset recordings under VOICE/FOLDER01..05. Probe deepest paths first.
DEFAULT_SOURCES=(
    "/Volumes/IC RECORDER/REC_FILE/FOLDER0"{1..5}
    "/Volumes/IC RECORDER/REC_FILE"
    "/Volumes/IC RECORDER/VOICE/FOLDER0"{1..5}
    "/Volumes/IC RECORDER/VOICE"
    "/Volumes/IC RECORDER"
)

SOURCE=""
PROMPT=1
DRYRUN=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        --source) SOURCE="$2"; shift 2 ;;
        --no-prompt) PROMPT=0; shift ;;
        --dry-run) DRYRUN=1; shift ;;
        -h|--help)
            sed -n '2,11p' "$0" | sed 's/^# \?//'
            exit 0
            ;;
        *) echo "Unknown arg: $1" >&2; exit 1 ;;
    esac
done

# Auto-detect recorder if no source given
if [[ -z "$SOURCE" ]]; then
    for candidate in "${DEFAULT_SOURCES[@]}"; do
        if [[ -d "$candidate" ]] && find "$candidate" -maxdepth 1 -type f \( -iname '*.mp3' -o -iname '*.wav' \) -print -quit | grep -q .; then
            SOURCE="$candidate"
            break
        fi
    done
fi

if [[ -z "$SOURCE" || ! -d "$SOURCE" ]]; then
    echo "Error: recorder not detected." >&2
    echo "  Plug in the recorder and ensure '/Volumes/IC RECORDER' is mounted." >&2
    echo "  Manual override: bbsync --source /path/to/recordings" >&2
    exit 1
fi

# Count audio files
file_count=$(find "$SOURCE" -maxdepth 1 -type f \( -iname '*.mp3' -o -iname '*.wav' \) | wc -l | tr -d ' ')
echo "Source: $SOURCE"
echo "Found $file_count audio file(s)"

if [[ "$file_count" -eq 0 ]]; then
    echo "Nothing to do."
    exit 0
fi

# --- Resume detection ---
# Unfinished stage = a session dir under $STAGE_BASE that bbsync didn't clean
# up because stage or push failed. Resuming reuses the SESSION timestamp so we
# land in the same host dir (mkdir -p is idempotent) and pick up partial files.
mkdir -p "$STAGE_BASE"
EXISTING_SESSION=""
shopt -s nullglob
for d in "$STAGE_BASE"/session-*; do
    [[ -d "$d" ]] || continue
    EXISTING_SESSION="$(basename "$d")"
    break
done
shopt -u nullglob

if [[ -n "$EXISTING_SESSION" ]]; then
    staged_files_n=$(find "$STAGE_BASE/$EXISTING_SESSION" -maxdepth 1 -type f \( -iname '*.mp3' -o -iname '*.wav' \) 2>/dev/null | wc -l | tr -d ' ')
    echo ""
    echo "Found unfinished stage: $EXISTING_SESSION ($staged_files_n file(s) staged)"
    read -p "Resume this session? [Y/n] " resume || resume=""
    if [[ "$resume" =~ ^[Nn]$ ]]; then
        echo "Discarding $STAGE_BASE/$EXISTING_SESSION and starting fresh."
        rm -rf "$STAGE_BASE/$EXISTING_SESSION"
        EXISTING_SESSION=""
    fi
fi

if [[ -n "$EXISTING_SESSION" ]]; then
    SESSION="$EXISTING_SESSION"
else
    SESSION="session-$(date -u +%Y%m%dT%H%M%SZ)"
fi
STAGE_DIR="$STAGE_BASE/$SESSION"
mkdir -p "$STAGE_DIR"
SESSION_REL="$HOST_INCOMING_REL/$SESSION"  # relative to remote $HOME

# Tag prompt. On resume, hitting Enter preserves any tags.txt already on host
# (the atomic-write upload is idempotent — empty TAGS means we don't touch it).
TAGS=""
if [[ "$PROMPT" -eq 1 ]]; then
    echo ""
    if [[ -n "$EXISTING_SESSION" ]]; then
        echo "Tags (Enter to keep existing host-side tags.txt, or retype to overwrite):"
    else
        echo "Today's context tags (comma-separated, e.g. 'project:foo, person:alice, activity:standup'):"
        echo "Leave empty to skip tagging."
    fi
    read -r TAGS || TAGS=""
fi

if [[ "$DRYRUN" -eq 1 ]]; then
    echo ""
    echo "[DRY RUN]"
    echo "  Session: $SESSION"
    echo "  Files:"
    find "$SOURCE" -maxdepth 1 -type f \( -iname '*.mp3' -o -iname '*.wav' \) -exec basename {} \; | sed 's/^/    /'
    [[ -n "$TAGS" ]] && echo "  Tags: $TAGS"
    echo "  Stage:       $STAGE_DIR"
    echo "  Destination: $HOST:~/$SESSION_REL/"
    echo "[DRY RUN end — no files transferred]"
    exit 0
fi

# --- Stage 1: rsync recorder → local SSD ---
# rsync with --partial preserves partial files across runs; on a USB drop,
# rerun bbsync (it auto-resumes via the stage dir) and rsync delta-transfer
# fills in the gaps. --timeout=120 bails fast if reads stall (so we surface
# USB death instead of hanging).
echo ""
echo "Staging $file_count file(s) to $STAGE_DIR..."
rsync -av --progress --partial --timeout=120 \
    --include='*.mp3' --include='*.wav' --include='*.MP3' --include='*.WAV' --exclude='*' \
    "$SOURCE"/ "$STAGE_DIR/" || {
    echo "" >&2
    echo "Stage failed (USB read error?). Partial files retained at $STAGE_DIR." >&2
    echo "Replug the recorder and rerun 'bbsync' — it will offer to resume." >&2
    exit 1
}
staged_count=$(find "$STAGE_DIR" -maxdepth 1 -type f \( -iname '*.mp3' -o -iname '*.wav' \) | wc -l | tr -d ' ')
echo "Staged $staged_count file(s)."

# Atomic session-dir creation + .uploading flag. Combined into ONE ssh call so
# the bounce processor can never observe a session_dir without the flag (closes
# the residual race between separate mkdir and touch invocations — without it,
# bounce could process an empty dir, prematurely fire cleanup_session, and strip
# tags.txt). Flag is cleared AFTER rsync completes successfully. If bbsync
# crashes mid-upload, the flag is left behind and visible via `bb status`.
echo ""
echo "Creating $SESSION on $HOST..."
ssh "$HOST" "mkdir -p \"\$HOME/$SESSION_REL\" && chmod 700 \"\$HOME/$SESSION_REL\" && touch \"\$HOME/$SESSION_REL/.uploading\""

# Upload tags sidecar atomically (write to .tmp + rename — guards against partial
# writes if the ssh stream dies mid-cat). Same-FS rename is atomic on ext4/btrfs.
if [[ -n "$TAGS" ]]; then
    ssh "$HOST" "cat > \"\$HOME/$SESSION_REL/tags.txt.tmp\" && mv \"\$HOME/$SESSION_REL/tags.txt.tmp\" \"\$HOME/$SESSION_REL/tags.txt\"" <<EOF
date: $(date -u +%Y-%m-%dT%H:%M:%SZ)
operator: $USER
host: $(hostname -s)
source_mount: $SOURCE
tags: $TAGS
EOF
    echo "Tags written."
fi

# --- Stage 2: rsync local stage → host ---
# Source is now stable local SSD, not flaky USB. RELATIVE path so rsync expands
# to remote user's $HOME.
echo "Uploading $staged_count file(s) to $HOST..."
rsync -av --progress --partial \
    --include='*.mp3' --include='*.wav' --include='*.MP3' --include='*.WAV' --exclude='*' \
    "$STAGE_DIR"/ "$HOST:$SESSION_REL/" || {
    echo "Push to $HOST failed. Staged files retained at $STAGE_DIR." >&2
    echo "Rerun 'bbsync' to resume (network only — recorder not required)." >&2
    echo ".uploading flag retained on $HOST for visibility — clear manually via:" >&2
    echo "  ssh $HOST \"rm -f \\\$HOME/$SESSION_REL/.uploading\"" >&2
    exit 1
}

# Clear atomicity flag — bounce can now process this session
ssh "$HOST" "rm -f \"\$HOME/$SESSION_REL/.uploading\""

# Stage delivered to host — local copy no longer needed.
rm -rf "$STAGE_DIR"

echo ""
echo "Uploaded $staged_count file(s) to $SESSION"
echo ""

# Offer to clean recorder. Tolerate non-tty / EOF stdin (piped invocations):
# set -e would otherwise kill the script on read returning nonzero, leaving the
# recorder un-wiped AND the script exit code falsely flagging upload failure.
read -p "Delete files from recorder? [y/N] " del || del=""
if [[ "$del" =~ ^[Yy]$ ]]; then
    find "$SOURCE" -maxdepth 1 -type f \( -iname '*.mp3' -o -iname '*.wav' \) -delete
    echo "Recorder cleaned."
else
    echo "Recorder files retained. Delete manually via the device or Finder when ready."
fi

echo ""
echo "Pipeline will pick up within ~60s. Monitor: bb log"
